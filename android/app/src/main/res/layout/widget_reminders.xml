<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_header"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="תזכורות" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_sub"
                android:textSize="12sp"
                android:maxLines="1"
                android:text="" />
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_switch"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="7dp"
            android:src="@drawable/ic_widget_list"
            android:contentDescription="החלפת רשימה" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="7dp"
            android:src="@drawable/ic_widget_refresh"
            android:contentDescription="רענון" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/widget_sub"
        android:textSize="14sp"
        android:visibility="gone"
        android:text="הכל בוצע — אין תזכורות פתוחות ✓" />
</LinearLayout>
