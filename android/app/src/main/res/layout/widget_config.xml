<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/widget_bg"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="איזו רשימה תוצג בווידג'ט?"
        android:textColor="@color/widget_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/config_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="פתח את האפליקציה פעם אחת כדי לסנכרן את כל הרשימות שלך."
        android:textColor="@color/widget_sub"
        android:textSize="13sp"
        android:paddingBottom="12dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/config_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />
</LinearLayout>
